# Sane defaults: let Git decide, normalize text line endings to LF in the repo.
* text=auto eol=lf

# --- Binary assets: never apply EOL conversion or text diffs ---
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.wav   binary
*.hex   binary
*.elf   binary
*.bin   binary

# 3D / CAD / fabrication (treat as binary blobs)
*.stl   binary
*.f3d   binary
*.step  binary
*.dxf   binary

# --- Explicit text types (kept LF) ---
*.svg   text eol=lf
*.md    text eol=lf
*.h     text eol=lf
*.ino   text eol=lf
*.py    text eol=lf
